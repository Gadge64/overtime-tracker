# ============================================================
# Overtime Tracker — Environment Variables
#
# 1. Copy this file to .env  (cp .env.example .env)
# 2. Fill in your Supabase project values below
# 3. Find them in: Supabase Dashboard → Settings → API
#
# The anon key is safe to expose in the browser — it only has
# the permissions allowed by your Row Level Security policies.
# ============================================================

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
